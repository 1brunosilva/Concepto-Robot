<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

<script>
gsap.registerPlugin(ScrollTrigger);

// ── CURSOR ──
const cd=document.getElementById('cd'),cr=document.getElementById('cr');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cd.style.left=mx+'px';cd.style.top=my+'px';
});
(function ac(){rx+=(mx-rx)*.11;ry+=(my-ry)*.11;cr.style.left=rx+'px';cr.style.top=ry+'px';requestAnimationFrame(ac);})();

// ── NAV ──
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('bg',window.scrollY>30);
},{passive:true});

// ── REVEAL ──
document.querySelectorAll('.rv').forEach(el=>{
  new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in');});},{threshold:.08}).observe(el);
});

// ── THREE.JS ──
const isMobile = window.innerWidth <= 680;
const canvas = document.getElementById('rc');
const renderer = new THREE.WebGLRenderer({canvas,alpha:true,antialias:!isMobile});
renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile?1.5:2));
renderer.setSize(window.innerWidth,window.innerHeight);
renderer.outputEncoding = THREE.sRGBEncoding;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.3;

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(35,window.innerWidth/window.innerHeight,.1,100);
camera.position.z = 5;

// Lights
scene.add(new THREE.AmbientLight(0xffffff,1.4));
const kl=new THREE.DirectionalLight(0xffffff,2.8);kl.position.set(2,4,3);scene.add(kl);
const fl=new THREE.DirectionalLight(0xf5f0e8,1.1);fl.position.set(-3,1,2);scene.add(fl);
const rl=new THREE.DirectionalLight(0xffffff,.7);rl.position.set(0,-2,-4);scene.add(rl);

// State object GSAP animates
const S={x:.26,y:0,sc:1,ry:0,rx:0,idle:0};
let mesh=null,loaded=false,idleT=0;

// World coordinate helpers
function worldW(){
  const h=2*Math.tan(camera.fov*Math.PI/360)*camera.position.z;
  return h*camera.aspect;
}
function worldH(){
  return 2*Math.tan(camera.fov*Math.PI/360)*camera.position.z;
}

function applyState(){
  if(!mesh)return;
  mesh.position.x = S.x*(worldW()/2);
  mesh.position.y = S.y*(worldH()/2)+Math.sin(idleT*.7)*.045;
  mesh.scale.setScalar(S.sc*1.85);
  mesh.rotation.y = S.ry+S.idle;
  mesh.rotation.x = S.rx;
}

// Sections → states
// x: .26=right half, -.26=left half, 0=center
// sc: scale drama — from .6 to 1.6
// x: -0.5=left edge, 0=center, 0.5=right edge
// y: -0.5=bottom, 0=center, 0.5=top
const DESKTOP_STATES=[
  // hero: right center, large, front
  {x:.28,  y:.02,  sc:1.1,  ry:0,         rx:0,    dur:1.2},
  // auto: left center, medium
  {x:-.28, y:-.05, sc:.92,  ry:.2,        rx:0,    dur:1.3},
  // webs: right center, normal
  {x:.26,  y:.05,  sc:1.0,  ry:-.2,       rx:0,    dur:1.2},
  // chatbots: left, LARGE closeup, center-low
  {x:-.24, y:-.08, sc:1.38, ry:.28,       rx:-.1,  dur:1.4},
  // marketing: right, small-far, center-high
  {x:.30,  y:.08,  sc:.68,  ry:-.25,      rx:.06,  dur:1.3},
  // ia: CENTER, MASSIVE, full spin
  {x:0,    y:0,    sc:1.55, ry:Math.PI*2, rx:-.1,  dur:1.6},
  // stats: background, center-top, tiny
  {x:0,    y:.42,  sc:.44,  ry:.1,        rx:.18,  dur:1.0},
  // cta: center, medium — leave room for text above
  {x:.05,  y:-.28, sc:1.05, ry:0,         rx:0,    dur:1.4},
];
// Mobile: robot travels around — different corner each section
// x range tighter (-0.35 to 0.35) so robot stays on screen
// y: .35=top area, -.35=bottom area
const MOBILE_STATES=[
  // hero: right, upper-center
  {x:.22,  y:.10,  sc:.70, ry:0,         rx:0,    dur:1.2},
  // auto: left, lower
  {x:-.18, y:-.30, sc:.62, ry:.2,        rx:0,    dur:1.3},
  // webs: right, lower
  {x:.20,  y:-.28, sc:.66, ry:-.2,       rx:0,    dur:1.2},
  // chatbots: left, upper
  {x:-.16, y:.14,  sc:.78, ry:.3,        rx:-.08, dur:1.4},
  // marketing: right, upper
  {x:.22,  y:.18,  sc:.58, ry:-.22,      rx:.05,  dur:1.3},
  // ia: center, BIG
  {x:0,    y:-.05, sc:.88, ry:Math.PI*2, rx:-.08, dur:1.6},
  // stats: center small
  {x:0,    y:.05,  sc:.42, ry:.1,        rx:.15,  dur:1.0},
  // cta: center lower
  {x:0,    y:-.32, sc:.72, ry:0,         rx:0,    dur:1.4},
];
const STATES = isMobile ? MOBILE_STATES : DESKTOP_STATES;

const SECS=['#s-hero','#s-auto','#s-webs','#s-chat','#s-mkt','#s-ia','#s-stats','#s-cta'];

function goTo(state){
  gsap.to(S,{
    x:state.x,y:state.y,sc:state.sc,ry:state.ry,rx:state.rx,
    duration:state.dur,
    ease:'power3.out',
    overwrite:'auto',
    onUpdate:applyState
  });
}

function setupST(){
  SECS.forEach((sel,i)=>{
    const el=document.querySelector(sel);
    if(!el||!STATES[i])return;
    ScrollTrigger.create({
      trigger:el,
      start:'top 58%',
      onEnter:()=>goTo(STATES[i]),
      onEnterBack:()=>goTo(STATES[i]),
    });
  });
  goTo(STATES[0]);
}

// Load robot
const loader=new THREE.GLTFLoader();
loader.load(
  'https://raw.githubusercontent.com/1brunosilva/Concepto-Robot/main/MaxNew.glb',
  gltf=>{
    mesh=gltf.scene;
    const box=new THREE.Box3().setFromObject(mesh);
    const c=box.getCenter(new THREE.Vector3());
    const sz=box.getSize(new THREE.Vector3());
    mesh.position.sub(c.multiplyScalar(1));
    // normalize
    const mx2=Math.max(sz.x,sz.y,sz.z);
    mesh.scale.setScalar(1/mx2);
    scene.add(mesh);
    loaded=true;
    setupST();
    setTimeout(()=>document.getElementById('ldr').classList.add('out'),400);
  },
  null,
  ()=>{ setTimeout(()=>document.getElementById('ldr').classList.add('out'),500); }
);
setTimeout(()=>document.getElementById('ldr').classList.add('out'),3500);

// Render + idle
(function loop(){
  requestAnimationFrame(loop);
  idleT+=.012;
  S.idle+=.006; // slow continuous spin
  if(loaded)applyState();
  renderer.render(scene,camera);
})();

// Resize
window.addEventListener('resize',()=>{
  camera.aspect=window.innerWidth/window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth,window.innerHeight);
});
</script>
</body>
</html>

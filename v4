<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Concepto Development</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --cream:#f5f4f0;
  --ink:#0d0d0d;
  --mid:#5a5a5a;
  --dim:#9e9b96;
  --black:#0d0d0d;
  --pad:clamp(24px,6vw,80px);
}
html{overflow-x:hidden;scroll-behavior:auto;}
body{
  background:var(--cream);
  color:var(--ink);
  font-family:'Inter',system-ui,-apple-system,sans-serif;
  font-weight:300;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}

/* ── CURSOR ── */
#cd,#cr{position:fixed;border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);}
#cd{width:5px;height:5px;background:var(--ink);}
#cr{width:28px;height:28px;border:1px solid rgba(13,13,13,.28);}
@media(hover:none){#cd,#cr{display:none;}}

/* ── LOADER ── */
#ldr{
  position:fixed;inset:0;background:var(--cream);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  z-index:8000;transition:opacity .5s;
}
#ldr.out{opacity:0;pointer-events:none;}
.ldr-logo{font-size:16px;font-weight:500;letter-spacing:-.02em;margin-bottom:2rem;color:var(--ink);}
.ldr-track{width:100px;height:1px;background:rgba(13,13,13,.1);overflow:hidden;}
.ldr-bar{width:0%;height:100%;background:var(--ink);animation:ldranim 1.6s ease forwards;}
@keyframes ldranim{to{width:100%;}}

/* ── CANVAS ── */
#rc{
  position:fixed;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:8;
}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:400;
  display:flex;justify-content:space-between;align-items:center;
  padding:0 var(--pad);height:60px;
}
nav.bg{background:rgba(245,244,240,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);}
.nl{font-size:15px;font-weight:500;letter-spacing:-.025em;color:var(--ink);text-decoration:none;}
.nlinks{display:flex;gap:2rem;align-items:center;}
.nlink{font-size:13px;color:var(--mid);text-decoration:none;font-weight:400;transition:color .18s;}
.nlink:hover{color:var(--ink);}
.nbtn{
  padding:.5rem 1.2rem;border-radius:100px;
  background:var(--ink);color:var(--cream);
  font-size:13px;font-weight:400;text-decoration:none;
  transition:opacity .18s;letter-spacing:-.01em;
}
.nbtn:hover{opacity:.72;}
.nmb{display:none;}
@media(max-width:680px){
  .nlinks{display:none;}
  .nmb{
    display:inline-flex;padding:.45rem 1rem;border-radius:100px;
    background:var(--ink);color:var(--cream);
    font-size:12px;font-weight:400;text-decoration:none;
  }
}

/* ── SECTIONS ── */
/* Each section is a full row: text LEFT, robot RIGHT */
/* Robot right half = transparent space (canvas draws there) */
section{
  position:relative;
  min-height:100vh;
  display:flex;align-items:center;
  padding:0 var(--pad);
  z-index:20;
}
.srow{
  display:grid;
  grid-template-columns:1fr 1fr;
  width:100%;
  align-items:center;
  gap:4vw;
}
.srow.flip{direction:rtl;}
.srow.flip .scol{direction:ltr;}
.scol{display:flex;flex-direction:column;justify-content:center;}
/* Right col: robot space - transparent, canvas renders there */
.rcol{
  height:70vh;
  position:relative;
  /* Invisible — robot canvas draws here */
}

/* ── TYPOGRAPHY ── */
.tag{
  font-size:11px;font-weight:500;letter-spacing:.16em;
  color:var(--dim);text-transform:uppercase;
  margin-bottom:1.6rem;display:block;
}
.h1{
  font-size:clamp(44px,6.5vw,96px);
  font-weight:600;
  letter-spacing:-.04em;
  line-height:.92;
  color:var(--ink);
}
.h2{
  font-size:clamp(38px,5.2vw,78px);
  font-weight:600;
  letter-spacing:-.04em;
  line-height:.92;
}
.fade{color:var(--dim);}
.sub{
  font-size:clamp(15px,1.15vw,17px);
  color:var(--mid);
  line-height:1.75;
  max-width:400px;
  margin-top:2rem;
  font-weight:300;
}
.lnk{
  display:inline-flex;align-items:center;gap:.35rem;
  margin-top:1.6rem;font-size:13px;color:var(--ink);
  text-decoration:none;font-weight:400;
  transition:gap .2s;
}
.lnk:hover{gap:.7rem;}
.lnk::after{content:'→';}

/* ── BUTTONS ── */
.brow{display:flex;gap:.65rem;margin-top:2.4rem;flex-wrap:wrap;}
.btn{
  display:inline-flex;align-items:center;
  padding:.72rem 1.7rem;border-radius:100px;
  font-family:'Inter',sans-serif;font-size:14px;font-weight:400;
  text-decoration:none;transition:opacity .18s;letter-spacing:-.01em;
}
.btn:hover{opacity:.65;}
.bd{background:var(--ink);color:var(--cream);}
.bo{background:transparent;color:var(--ink);border:1px solid rgba(13,13,13,.18);}

/* ── STATS ── */
#s-stats{
  background:var(--black);color:var(--cream);
  min-height:60vh;padding:8vh var(--pad);
  display:flex;align-items:center;justify-content:center;
}
.sg{
  display:grid;grid-template-columns:repeat(3,1fr);
  width:100%;max-width:980px;
}
.st{padding:2.5rem 2rem;}
.st:not(:last-child){border-right:1px solid rgba(255,255,255,.07);}
.stn{
  font-size:clamp(48px,5.5vw,80px);
  font-weight:600;letter-spacing:-.04em;line-height:1;
  display:block;color:var(--cream);
}
.stl{
  font-size:12px;color:rgba(245,244,240,.35);
  margin-top:.8rem;display:block;letter-spacing:.04em;
  text-transform:uppercase;font-weight:400;
}

/* ── PROCESS ── */
#s-proc{
  min-height:auto;padding:10vh var(--pad);
  display:block;
}
.ptag{
  font-size:11px;font-weight:500;letter-spacing:.16em;
  color:var(--dim);text-transform:uppercase;
  margin-bottom:3.5rem;display:block;
}
.pg{display:grid;grid-template-columns:repeat(4,1fr);gap:3rem;}
.pn{
  font-size:11px;font-weight:500;color:var(--dim);
  letter-spacing:.1em;margin-bottom:1rem;display:block;
}
.pt{
  font-size:clamp(16px,1.4vw,19px);font-weight:500;
  letter-spacing:-.02em;margin-bottom:.5rem;
}
.pp{font-size:13px;color:var(--mid);line-height:1.75;font-weight:300;}

/* ── CTA ── */
#s-cta{
  display:flex;flex-direction:column;
  align-items:center;text-align:center;
  justify-content:flex-start;
  padding-top:14vh;
  min-height:100vh;padding-left:var(--pad);padding-right:var(--pad);
}
.ctah{
  font-size:clamp(42px,6.5vw,100px);
  font-weight:600;letter-spacing:-.04em;line-height:.92;
  max-width:62vw;text-align:center;
}
.ctap{
  font-size:clamp(14px,1.1vw,16px);color:var(--mid);
  max-width:340px;line-height:1.8;margin-top:1.6rem;font-weight:300;
}

/* ── FOOTER ── */
footer{
  padding:2.5rem var(--pad);
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid rgba(13,13,13,.06);z-index:20;position:relative;
}
.fl{font-size:14px;font-weight:500;letter-spacing:-.02em;}
.fls{display:flex;gap:1.5rem;}
.fla{font-size:12px;color:var(--dim);text-decoration:none;transition:color .18s;}
.fla:hover{color:var(--ink);}
.fc{font-size:12px;color:var(--dim);}

/* ── REVEAL ── */
.rv{opacity:0;transform:translateY(32px);transition:opacity .85s cubic-bezier(.16,1,.3,1),transform .85s cubic-bezier(.16,1,.3,1);}
.rv.in{opacity:1;transform:none;}
.d1{transition-delay:.1s;}.d2{transition-delay:.2s;}.d3{transition-delay:.32s;}

/* ── MOBILE ── */
@media(max-width:680px){
  /* Mobile sections: text at top, robot moves freely via canvas */
  section{
    min-height:100vh;
    padding:80px var(--pad) 80px;
    display:flex;align-items:flex-start;
  }
  #s-hero{padding-top:110px;padding-bottom:80px;}

  .srow{grid-template-columns:1fr;direction:ltr !important;width:100%;}
  .rcol{display:none;}

  .h1{font-size:clamp(38px,12vw,56px);line-height:.95;}
  .h2{font-size:clamp(32px,10.5vw,50px);line-height:.95;}
  .sub{max-width:100%;font-size:15px;margin-top:1.4rem;}
  .brow{margin-top:1.8rem;}
  .tag{margin-bottom:1.2rem;}

  /* Stats */
  #s-stats{
    min-height:auto;padding:60px var(--pad);
    display:flex;align-items:center;
  }
  .sg{grid-template-columns:1fr;}
  .st:not(:last-child){border-right:none;border-bottom:1px solid rgba(255,255,255,.07);}
  .st{padding:1.8rem 0;}
  .stn{font-size:clamp(44px,12vw,64px);}

  /* Process */
  #s-proc{min-height:auto;padding:60px var(--pad);}
  .pg{grid-template-columns:1fr 1fr;gap:1.8rem;}

  /* CTA */
  #s-cta{
    min-height:100vh;padding:80px var(--pad) 80px;
    align-items:flex-start;text-align:left;
    justify-content:flex-start;
  }
  .ctah{font-size:clamp(34px,11vw,52px);max-width:100%;text-align:left;}
  .ctap{max-width:100%;}
  #s-cta .brow{justify-content:flex-start;}

  footer{flex-direction:column;gap:1rem;text-align:center;padding:2rem var(--pad);}
  .fls{justify-content:center;flex-wrap:wrap;}
}
@media(max-width:400px){
  .pg{grid-template-columns:1fr;}
  section{padding-bottom:300px;}
}
</style>
</head>
